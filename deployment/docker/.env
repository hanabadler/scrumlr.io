# Backend
SCRUMLR_BACKEND_VERSION=5.0.0
SCRUMLR_LOG_LEVEL=INFO
SCRUMLR_SERVER_PORT=8080
SCRUMLR_BASE_PATH=/api
SCRUMLR_INSECURE=false
SCRUMLR_PRIVATE_KEY=change_me
SCRUMLR_SERVER_NATS_URL=nats://nats:4222
SESSION_SECRET=supersecret

# Frontend
SCRUMLR_FRONTEND_VERSION=5.0.0
SCRUMLR_LISTEN_PORT=8080
SCRUMLR_SERVER_URL=/api
SCRUMLR_WEBSOCKET_URL=ws://scrumlr-backend:8080/api
SCRUMLR_SHOW_LEGAL_DOCUMENTS=true
FRONTEND_PORT=8081

# Postgres
POSTGRES_VERSION=15
POSTGRES_USER=scrumlr
POSTGRES_PASSWORD=scrumlr123
POSTGRES_DB=scrumlr

# NATS
NATS_VERSION=2.10
